							UserControls = ordered() {
								BaseWidth = { INPID_InputControl = "SliderControl", INP_Default = 0.4, INP_MinScale = 0.05, INP_MaxScale = 1.5, INP_MinAllowed = 0.001, INP_MaxAllowed = 5, LINKID_DataType = "Number", LINKS_Name = "Width (Length)", ICS_ControlPage = "Highlight", },
								BaseHeight = { INPID_InputControl = "SliderControl", INP_Default = 0.09, INP_MinScale = 0.01, INP_MaxScale = 1, INP_MinAllowed = 0.001, INP_MaxAllowed = 5, LINKID_DataType = "Number", LINKS_Name = "Height (Thickness)", ICS_ControlPage = "Highlight", },
