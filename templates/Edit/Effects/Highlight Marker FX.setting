								RightAudio = Input { SourceOp = "Right", Source = "Data", }
							},
							ViewInfo = OperatorInfo { Pos = { -550, 8.75 } },
							Version = 1
						},
						ColorBG = Background {
							CtrlWShown = false,
							Inputs = {
								Width = Input { Expression = "comp:GetPrefs(\"Comp.FrameFormat.Width\")", },
								Height = Input { Expression = "comp:GetPrefs(\"Comp.FrameFormat.Height\")", },
								["Gamut.SLogVersion"] = Input { Value = FuID { "SLog2" }, },
								TopLeftRed = Input { Value = 1, Expression = "iif(ColorBG.Preset==0,1.0,iif(ColorBG.Preset==1,0.55,iif(ColorBG.Preset==2,1.0,iif(ColorBG.Preset==3,0.2,iif(ColorBG.Preset==4,1.0,iif(ColorBG.Preset==5,0.65,ColorBG.CustomRed))))))", },
								TopLeftGreen = Input { Value = 0.92, Expression = "iif(ColorBG.Preset==0,0.92,iif(ColorBG.Preset==1,0.95,iif(ColorBG.Preset==2,0.3,iif(ColorBG.Preset==3,0.65,iif(ColorBG.Preset==4,0.5,iif(ColorBG.Preset==5,0.3,ColorBG.CustomGreen))))))", },
								TopLeftBlue = Input { Value = 0, Expression = "iif(ColorBG.Preset==0,0.0,iif(ColorBG.Preset==1,0.1,iif(ColorBG.Preset==2,0.65,iif(ColorBG.Preset==3,1.0,iif(ColorBG.Preset==4,0.05,iif(ColorBG.Preset==5,0.95,ColorBG.CustomBlue))))))", },
								TopLeftAlpha = Input { Value = 1, }
							},
							ViewInfo = OperatorInfo { Pos = { -440, 90 } },
							UserControls = ordered() {
								Preset = {
									INPID_InputControl = "ComboControl",
									INP_Integer = true,
									INP_Default = 0,
									LINKID_DataType = "Number",
									LINKS_Name = "Color Preset",
									ICS_ControlPage = "Highlight",
									{ CCS_AddString = "Yellow (Marker)" },
									{ CCS_AddString = "Green" },
									{ CCS_AddString = "Pink" },
									{ CCS_AddString = "Blue" },
									{ CCS_AddString = "Orange" },
									{ CCS_AddString = "Purple" },
									{ CCS_AddString = "Custom" },
								},
								DrawTime = { INPID_InputControl = "SliderControl", INP_Integer = true, INP_Default = 20, INP_MinScale = 0, INP_MaxScale = 120, INP_MinAllowed = 0, INP_MaxAllowed = 600, LINKID_DataType = "Number", LINKS_Name = "Intro Draw Time (Frames)", ICS_ControlPage = "Animation", },
								OutTime = { INPID_InputControl = "SliderControl", INP_Integer = true, INP_Default = 15, INP_MinScale = 0, INP_MaxScale = 120, INP_MinAllowed = 0, INP_MaxAllowed = 600, LINKID_DataType = "Number", LINKS_Name = "Outro Erase Time (Frames, 0=off)", ICS_ControlPage = "Animation", },
								CustomRed = { INPID_InputControl = "ColorControl", INP_Default = 1, LINKID_DataType = "Number", LINKS_Name = "Custom Color", ICS_ControlPage = "Highlight", IC_ControlGroup = 10, IC_ControlID = 0, ICD_Center = 1, },
								CustomGreen = { INPID_InputControl = "ColorControl", INP_Default = 0.4, LINKID_DataType = "Number", IC_ControlGroup = 10, IC_ControlID = 1, },
								CustomBlue = { INPID_InputControl = "ColorControl", INP_Default = 0.9, LINKID_DataType = "Number", IC_ControlGroup = 10, IC_ControlID = 2, },
							}
						},
						MultMerge = Merge {
							CtrlWShown = false,
							Inputs = {
								Background = Input { SourceOp = "MediaIn1_1", Source = "Output", },
								Foreground = Input { SourceOp = "ColorBG", Source = "Output", },
								ApplyMode = Input { Value = FuID { "Darken" }, },
