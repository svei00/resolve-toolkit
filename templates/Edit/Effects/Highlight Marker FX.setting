						Input3  = InstanceInput { SourceOp = "HiliteMask", Source = "BaseHeight", Name = "Height (Thickness)", MinScale = 0.01, MaxScale = 1, Page = "Highlight", Default = 0.09, },
						Input4  = InstanceInput { SourceOp = "HiliteMask", Source = "Zoom", Name = "Zoom (Overall Size)", MinScale = 0.1, MaxScale = 4, Page = "Highlight", Default = 1, },
						Input5  = InstanceInput { SourceOp = "HiliteMask", Source = "Angle", Name = "Rotation", Page = "Highlight", Default = 0, },
						Input6  = InstanceInput { SourceOp = "HiliteMask", Source = "CornerRadius", Name = "End Roundness", MinScale = 0, MaxScale = 1, Page = "Highlight", Default = 0.5, },
						Input7  = InstanceInput { SourceOp = "MultMerge", Source = "ApplyMode", Name = "Blend Mode (Darken/Multiply/Lighten/Linear Burn/Normal)", Page = "Highlight", },
						Input8  = InstanceInput { SourceOp = "ColorBG", Source = "Preset", Name = "Color Preset", Page = "Highlight", Default = 0, },
						Input9  = InstanceInput { SourceOp = "MultMerge", Source = "Blend", Name = "Highlight Opacity", MinScale = 0, MaxScale = 1, Page = "Highlight", Default = 1, },
						Input10 = InstanceInput { SourceOp = "ColorBG", Source = "CustomRed",   Name = "Custom Color", ControlGroup = 5, Page = "Highlight", Default = 1, },
						Input11 = InstanceInput { SourceOp = "ColorBG", Source = "CustomGreen", ControlGroup = 5, Default = 0.4, },
						Input12 = InstanceInput { SourceOp = "ColorBG", Source = "CustomBlue",  ControlGroup = 5, Default = 0.9, },
						Input13 = InstanceInput { SourceOp = "ColorBG", Source = "DrawTime", Name = "Intro Draw Time (Frames)", Page = "Animation", Default = 20, },
						Input14 = InstanceInput { SourceOp = "ColorBG", Source = "OutTime", Name = "Outro Erase Time (Frames, 0=off)", Page = "Animation", Default = 15, }
					},
					Outputs = {
						MainOutput = InstanceOutput { SourceOp = "FinalMerge", Source = "Output", }
					},
					ViewInfo = GroupInfo { Pos = { 0, 0 } },
					Tools = ordered() {
						MediaIn1_1 = MediaIn {
							ExtentSet = true,
							CtrlWZoom = false,
							CtrlWShown = false,
							CustomData = { MediaProps = { MEDIA_HEIGHT = 1080, MEDIA_AUDIO_TRACKS_DESC = { { MEDIA_AUDIO_BIT_DEPTH = 32, MEDIA_AUDIO_TRACK_ID = "Timeline Audio", MEDIA_AUDIO_TRACK_NAME = "Timeline Audio [Timeline 1]", MEDIA_AUDIO_FRAME_RATE = 30, MEDIA_AUDIO_START_TIME = 0, MEDIA_AUDIO_SAMPLE_RATE = 48000, MEDIA_AUDIO_NUM_CHANNELS = 2 } }, MEDIA_IS_SOURCE_RES = false, MEDIA_PAR = 1, MEDIA_START_FRAME = 0, MEDIA_WIDTH = 1920, MEDIA_AUDIO_TRACKS_NUM = 1, MEDIA_SRC_FRAME_RATE = 30, MEDIA_MARK_OUT = 246, MEDIA_HAS_AUDIO = true, MEDIA_NUM_FRAMES = 247, MEDIA_MARK_IN = 0, MEDIA_NAME = "Adjustment Clip" }, },
							Inputs = {
								GlobalOut = Input { Value = 246, },
								AudioTrack = Input { Value = FuID { "Timeline Audio" }, },
								Layer = Input { Value = "", },
								ClipTimeEnd = Input { Value = 246, },
								DeepOutputMode = Input { Value = 0, Disabled = true, },
