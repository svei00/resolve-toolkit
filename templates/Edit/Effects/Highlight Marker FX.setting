				Input2  = InstanceInput { SourceOp = "HLMarkerCore", Source = "Input2",  Page = "Highlight", Default = 0.4, },
				Input3  = InstanceInput { SourceOp = "HLMarkerCore", Source = "Input3",  Page = "Highlight", Default = 0.09, },
