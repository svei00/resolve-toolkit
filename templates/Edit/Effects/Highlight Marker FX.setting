							},
							ViewInfo = OperatorInfo { Pos = { -330, 8.75 } },
						},
						WipeMask = RectangleMask {
							CtrlWShown = false,
							Inputs = {
								Filter = Input { Value = FuID { "Fast Gaussian" }, },
								SoftEdge = Input { Value = 0.02, },
								MaskWidth = Input { Expression = "comp:GetPrefs(\"Comp.FrameFormat.Width\")", },
								MaskHeight = Input { Expression = "comp:GetPrefs(\"Comp.FrameFormat.Height\")", },
								PixelAspect = Input { Value = { 1, 1 }, },
								ClippingMode = Input { Value = FuID { "None" }, },
								Center = Input { Expression = "Point((max(0,min(1,((min(1,max(0,iif(ColorBG.DrawTime<=0,1,time/ColorBG.DrawTime))))*(min(1,max(0,iif(ColorBG.DrawTime<=0,1,time/ColorBG.DrawTime))))*(3-2*(min(1,max(0,iif(ColorBG.DrawTime<=0,1,time/ColorBG.DrawTime))))))-((iif(ColorBG.OutTime<=0,0,min(1,max(0,(time-(comp.RenderEnd-ColorBG.OutTime))/max(ColorBG.OutTime,1)))))*(iif(ColorBG.OutTime<=0,0,min(1,max(0,(time-(comp.RenderEnd-ColorBG.OutTime))/max(ColorBG.OutTime,1)))))*(3-2*(iif(ColorBG.OutTime<=0,0,min(1,max(0,(time-(comp.RenderEnd-ColorBG.OutTime))/max(ColorBG.OutTime,1))))))))))/2,0.5)", },
								Width = Input { Value = 1, Expression = "(max(0,min(1,((min(1,max(0,iif(ColorBG.DrawTime<=0,1,time/ColorBG.DrawTime))))*(min(1,max(0,iif(ColorBG.DrawTime<=0,1,time/ColorBG.DrawTime))))*(3-2*(min(1,max(0,iif(ColorBG.DrawTime<=0,1,time/ColorBG.DrawTime))))))-((iif(ColorBG.OutTime<=0,0,min(1,max(0,(time-(comp.RenderEnd-ColorBG.OutTime))/max(ColorBG.OutTime,1)))))*(iif(ColorBG.OutTime<=0,0,min(1,max(0,(time-(comp.RenderEnd-ColorBG.OutTime))/max(ColorBG.OutTime,1)))))*(3-2*(iif(ColorBG.OutTime<=0,0,min(1,max(0,(time-(comp.RenderEnd-ColorBG.OutTime))/max(ColorBG.OutTime,1))))))))))", },
								Height = Input { Value = 1, }
							},
							ViewInfo = OperatorInfo { Pos = { -220, 120 } },
						},
						HiliteMask = RectangleMask {
							CtrlWShown = false,
							Inputs = {
								EffectMask = Input { SourceOp = "WipeMask", Source = "Mask", },
								PaintMode = Input { Value = FuID { "Multiply" }, },
								Filter = Input { Value = FuID { "Fast Gaussian" }, },
								SoftEdge = Input { Value = 0.0225, Expression = "HiliteMask.BaseHeight*HiliteMask.Zoom*0.25", },
								MaskWidth = Input { Expression = "comp:GetPrefs(\"Comp.FrameFormat.Width\")", },
								MaskHeight = Input { Expression = "comp:GetPrefs(\"Comp.FrameFormat.Height\")", },
								PixelAspect = Input { Value = { 1, 1 }, },
								ClippingMode = Input { Value = FuID { "None" }, },
								Center = Input { Value = { 0.5, 0.5 }, },
								Width = Input { Value = 0.4, Expression = "HiliteMask.BaseWidth*HiliteMask.Zoom", },
								Height = Input { Value = 0.09, Expression = "HiliteMask.BaseHeight*HiliteMask.Zoom", },
								Angle = Input { Value = 0, },
								CornerRadius = Input { Value = 0.5, }
